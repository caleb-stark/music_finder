<%- include('partials/head') %>
<%- include('partials/nav') %>

<div class="container mt-4">
  <h1 class="text-center mb-4"><%= playlistName %></h1>
  <div class="text-end mb-3">
    <button id="toggleDeleteMode" class="btn btn-warning">Multi‑Delete Mode</button>
  </div>
  <form action="/playlist/<%= playlistId %>/delete-multiple" method="POST" id="multiDeleteForm">
    <div class="card shadow-sm">
      <div class="card-body">
        <table class="table table-striped table-hover align-middle">
          <thead class="table-primary">
            <tr>
              <th id="checkboxHeader" style="display:none;">Select</th>
              <th>Song Title</th>
              <th>Artist</th>
              <th class="text-end">Remove</th>
            </tr>
          </thead>
          <tbody>
            <% if (songs.length === 0) { %>
            <tr>
              <td colspan="4" class="text-center text-muted">
                This playlist has no songs yet.
              </td>
            </tr>
            <% } %>
            <% songs.forEach(song => { %>
            <tr>
              <!-- Checkbox (hidden until multi-delete mode) -->
              <td style="display:none;" class="checkboxCell">
                <input type="checkbox" name="spotifyIds" value="<%= song.spotify_id %>" class="form-check-input delete-checkbox">
              </td>
              <td><%= song.song_title %></td>
              <td><%= song.artist_name %></td>
              <td class="text-end single-delete">
                <a href="/removesong/<%= playlistId %>/<%= song.spotify_id %>" class="btn btn-sm btn-danger">
                  x
                </a>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Delete Selected button -->
    <div class="text-end mt-3">
      <button type="submit" id="deleteSelectedBtn" class="btn btn-danger" style="display:none;">
        Delete Selected
      </button>
    </div>
  </form>

  <div class="text-center mt-4">
    <a href="/playlist" class="btn btn-secondary">Back to Playlists</a>
  </div>
</div>
<script>
document.getElementById("toggleDeleteMode").addEventListener("click", () => {
  const checkboxes = document.querySelectorAll(".checkboxCell");
  const deleteBtn = document.getElementById("deleteSelectedBtn");
  const singleDeleteButtons = document.querySelectorAll(".single-delete");
  const checkboxHeader = document.getElementById("checkboxHeader");
  const isHidden = checkboxes[0]?.style.display === "none";
  checkboxes.forEach(cb => cb.style.display = isHidden ? "table-cell" : "none");
  singleDeleteButtons.forEach(btn => btn.style.display = isHidden ? "none" : "table-cell");
  deleteBtn.style.display = isHidden ? "inline-block" : "none";
  checkboxHeader.style.display = isHidden ? "table-cell" : "none";
});
</script>

<%- include('partials/footer') %>
