<%- include('partials/head') %>

<% if (error) { %>
  <p class="movie-error"><%= error %></p>
<% } else if (movie) { %>
  <div class="movie-card">
    <img
      class="movie-poster"
      src="<%= movie.Poster !== 'N/A' ? movie.Poster : 'img/no-poster.png' %>"
      alt="<%= movie.Title %> poster"
    >
    <div class="movie-info">
      <h2 class="movie-title"><%= movie.Title %></h2>
      <p class="movie-year"><%= movie.Year %></p>
      <p class="movie-genre"><%= movie.Genre %></p>
      <p class="movie-rated"><%= movie.Rated %></p>
      <p class="movie-plot"><%= movie.Plot %></p>
    </div>
  </div>

  <h4 class="text-center">Songs in this Movie</h4>

  <div class="container" style="max-width: 600px;">
    <% for (let song of songs) { %>
      <div class="card mb-3 shadow-sm">
        <div class="row g-0 align-items-center">
          <div class="col-auto">
            <img src="<%= song.album_art_url %>" 
                alt="<%= song.song_title %> album art"
                style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px 0 0 8px;">
          </div>
          <div class="col p-3">
            <h6 class="mb-1 fw-bold"><%= song.song_title %></h6>
            <p class="mb-0 text-muted small"><%= song.artist_name %></p>
          </div>
        </div>
      </div>
    <% } %>
  </div>
<% } %>

<%- include('partials/footer') %>